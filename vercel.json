{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "rewrites": [
    {
      "source": "/login",
      "destination": "/login/"
    },
    {
      "source": "/otp",
      "destination": "/otp/"
    }
  ]
}
